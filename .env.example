# Copy to .env and adjust. Do not commit .env (secrets).

# --- Database (required) ---
# Postgres connection URI. Get from Supabase: Project Settings → Database → Connection string (URI).
# Prefer Session mode (port 5432) for this app: Connect → Session mode in dashboard.
# Transaction mode (6543) also works; the app disables prepared statements for it.
# Format: postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
# (This is not the project URL https://xxx.supabase.co.) SSL is added automatically for pooler URLs.
# If pooler fails (e.g. "connection reset"), use Direct: Supabase → Connect → Direct, copy URI.
# Direct uses IPv6; add ?gssencmode=disable to avoid GSSAPI errors. Optional: set DIRECT_DATABASE_URL
# to the exact Direct URI for scripts/test_db_connection.py to try it.
# DATABASE_URL=

# --- OpenAI (default when set) ---
# When set, embeddings and LLM use OpenAI first. Optional: set EMBED_FALLBACK_TO_LOCAL and/or
# LLM_FALLBACK_TO_LOCAL to true to use Ollama when OpenAI fails (timeout, rate limit, etc.).
# OPENAI_API_KEY=

# --- Embeddings: OpenAI (text-embedding-3-small, 768 dim) or Ollama ---
EMBED_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
EMBED_TIMEOUT=30
EMBED_MAX_ATTEMPTS=3
# Use local (Ollama) only for embeddings; ignores OPENAI_API_KEY for embeddings (saves cost, no rate limits).
# EMBED_LOCAL_ONLY=true
# EMBED_FALLBACK_TO_LOCAL=false

# --- LLM: OpenAI or Ollama ---
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b
# LLM_OPENAI_MODEL=gpt-4o-mini
# Low (not zero) default keeps answers stable; eval harness overrides to 0.0 internally.
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_ATTEMPTS=3
LLM_RATE_LIMIT_SECONDS=60
LLM_TOKEN_LIMIT=10
# LLM_FALLBACK_TO_LOCAL=false

# --- Google Drive (optional) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# Team inbox folder (ID or full drive.google.com/.../folders/... URL). Used when API/UI omit folder_id.
# GOOGLE_DRIVE_DEFAULT_FOLDER_ID=1HUgl4ryKyijBOP4_nJkJCCT3mvLdKPih
# Human-readable label shown in the Drive tab when viewing the team inbox (not a secret).
# GOOGLE_DRIVE_DEFAULT_FOLDER_LABEL=Shared drives / Team / Ready for AI Ingest
# Jobs root for Report Writer address → photo folder lookup (immediate subfolders).
# GOOGLE_DRIVE_JOBS_ROOT_FOLDER_ID=1jQAkbysP7QUhhjVbvYdHDvl5drthv5O
# GOOGLE_DRIVE_JOBS_ROOT_FOLDER_LABEL=Shared drives / Jobs

# --- Supabase Auth (required for protected API) ---
# From Supabase: Project Settings → API. URL = Project URL; anon key = anon public; JWT Secret = JWT Secret.
# SUPABASE_URL=https://YOUR_REF.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_JWT_SECRET=your-jwt-secret
# Optional: canonical app URL for password-reset emails (redirect). No trailing slash. If unset, the browser origin is used.
# PUBLIC_APP_URL=https://app.example.com

# --- CORS (optional: split-origin frontend, e.g. Vite on :5173) ---
# Comma-separated list. Example: http://localhost:5173,https://app.example.com
# CORS_ORIGINS=


# --- Ingest background worker ---
# Processes Postgres ingest_jobs queue in-process (same uvicorn worker). Set 0 to disable.
# INGEST_WORKER_ENABLED=1

# --- Health checks ---
# Liveness: GET /health (process up). Readiness: GET /health/ready (SELECT 1 on Postgres).
# Set Render (or LB) health check path to /health/ready, not /health.
# Deep probe: GET /health/deep (DB + embed; optional LLM). Do not use /health/deep for high-frequency LB polls.
# HEALTH_DEEP_TIMEOUT=5
# HEALTH_DEEP_CHECK_LLM=false

# --- Prometheus metrics (optional) ---
# METRICS_ENABLED=true
# If set, scrape GET /metrics with header: Authorization: Bearer <token>
# METRICS_TOKEN=
# Optional: alert when retrieval returns chunks but best cosine similarity is below this (0–1).
# RAG_SIMILARITY_ALERT_THRESHOLD=0.35
