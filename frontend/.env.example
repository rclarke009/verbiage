# Dev: leave empty to use Vite proxy to FastAPI (see vite.config.ts).
# Split origins (e.g. Vercel UI + Render API): set to your API origin, e.g. https://api.example.com
# VITE_API_ORIGIN=

# Optional: where to proxy in dev (default http://127.0.0.1:8000)
# VITE_PROXY_API=http://127.0.0.1:8000

# Build SPA into repo ../static/ for same-origin Docker deploy (see package.json build:static)
# DEPLOY_STATIC=1

# Show Vision tab (still needs backend route to do anything useful)
# VITE_FEATURE_VISION=false
